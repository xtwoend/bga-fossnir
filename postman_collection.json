                  "description": "Start date"
                },
                {
                  "key": "to",
                  "value": "2025-01-05",
                  "description": "End date"
                },
                {
                  "key": "parameter",
                  "value": "Oil/WM",
                  "description": "Parameter (default: Oil/WM)"
