                {
                  "key": "group_id",
                  "value": "4",
                  "description": "Group ID"
                },
                {
                  "key": "parameter",
                  "value": "owm",
                  "description": "Parameter"
                }
              ]
            },
            "description": "Get daily fossnir data summary"
