              "raw": "{{base_url}}/fossnir/report/:id?from=2025-01-01&to=2025-01-05&product=&parameter=",
              "host": ["{{base_url}}"],
              "path": ["fossnir", "report", ":id"],
              "query": [
                {
                  "key": "from",
                  "value": "2025-01-01",
                  "description": "Start date (default: yesterday)"
                },
                {
                  "key": "to",
                  "value": "2025-01-05",
                  "description": "End date (default: today)"
                },
                {
                  "key": "product",
                  "value": "",
                  "description": "Product name filter"
                },
                {
                  "key": "parameter",
                  "value": "",
                  "description": "Parameter filter"
                }
              ],
              "variable": [
                {
                  "key": "id",
                  "value": "1",
                  "description": "Mill ID"
                }
              ]
            },
            "description": "Get mill report data with date range and filters"
          },
          "response": []
        },
