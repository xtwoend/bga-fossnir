        {
          "name": "Get Fossnir Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/fossnir/data?date=2025-01-05&group_id=4&parameter=owm&mill_id=",
              "host": ["{{base_url}}"],
              "path": ["fossnir", "data"],
              "query": [
                {
                  "key": "date",
                  "value": "2025-01-05",
                  "description": "Date (default: today)"
                },
                {
                  "key": "group_id",
                  "value": "4",
                  "description": "Group ID (default: 4)"
                },
                {
                  "key": "parameter",
                  "value": "owm",
                  "description": "Parameter: owm, vm, odm, nos (default: owm)"
                },
                {
                  "key": "mill_id",
                  "value": "",
                  "description": "Optional mill ID filter, use 999 for all mills"
                }
              ]
            },
            "description": "Get fossnir data with 2-hour intervals from 05:00 to 05:00 next day"
          },
          "response": []
        },
        {
          "name": "Get Daily Data",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/fossnir/daily?date=2025-01-05&group_id=4&parameter=owm",
