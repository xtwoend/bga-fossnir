    {
      "name": "News",
      "item": [
        {
          "name": "Get Latest News",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/news?mill_id=",
              "host": ["{{base_url}}"],
              "path": ["news"],
              "query": [
                {
                  "key": "mill_id",
                  "value": "",
                  "description": "Optional: Filter by mill ID"
                }
              ]
            },
            "description": "Get latest news, optionally filtered by mill_id"
          },
          "response": []
        }
      ]
    },
    {
