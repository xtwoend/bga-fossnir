            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": [\n    {\n      \"sample_date\": \"2025-01-05 10:00:00\",\n      \"device_id\": 1,\n      \"product_name\": \"Product A\",\n      \"parameter\": \"Oil/WM\",\n      \"result\": 5.5\n    },\n    {\n      \"sample_date\": \"2025-01-05 11:00:00\",\n      \"device_id\": 1,\n      \"product_name\": \"Product B\",\n      \"parameter\": \"Oil/WM\",\n      \"result\": 6.2\n    }\n  ]\n}"
